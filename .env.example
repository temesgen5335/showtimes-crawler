# --- Server ---
PORT=3333
# Mount point for the Bull Board queue dashboard.
BULL_BOARD_ROUTE=/admin/queues

# --- Redis (BullMQ queue store) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Crawler behaviour ---
# Default fetch engine: "http" (Axios + Cheerio) or "browser" (Puppeteer).
# Can be overridden per job via the "engine" field of POST /crawl.
FETCH_ENGINE=http
# Per-request timeout in milliseconds.
FETCH_TIMEOUT_MS=15000
# Number of attempts per job before it is marked as failed (BullMQ retries
# with exponential backoff between attempts).
JOB_ATTEMPTS=2

# --- Rate limiting (protects target sites and your proxy pool) ---
# The BullMQ worker processes at most RATE_LIMIT_MAX jobs per
# RATE_LIMIT_DURATION_MS window, across all queued jobs.
RATE_LIMIT_MAX=5
RATE_LIMIT_DURATION_MS=1000
# How many jobs a single worker may run concurrently.
WORKER_CONCURRENCY=3

# --- Proxy / VPN rotation (Part 2) ---
# Comma-separated list of proxy URLs. Each fetch picks the next proxy in
# round-robin order. Supports authenticated proxies:
#   http://user:pass@proxy-host:8080
# Works with any HTTP(S) proxy provider (datacenter, residential pools such
# as Bright Data / Oxylabs, or a local VPN gateway exposed as an HTTP proxy).
# Leave empty to fetch directly without a proxy.
PROXY_URLS=
